---
const posts = [
  {
    title: 'Автоматизация продольного профиля в Топоматик Robur',
    excerpt: 'Как ускорить работу с профилем с помощью скриптов и кастомных инструментов.',
    date: '2025-06-01',
    tag: 'Топоматик Robur',
    slug: 'avtomatizatsiya-profilya-robur',
  },
  {
    title: 'Dynamo для Civil 3D: первые шаги в BIM-автоматизации',
    excerpt: 'Разбираем базовые скрипты Dynamo для генерации геометрии дорожного коридора.',
    date: '2025-05-15',
    tag: 'Dynamo / BIM',
    slug: 'dynamo-civil3d-pervye-shagi',
  },
  {
    title: 'Обзор обновлений Robur 2025.1',
    excerpt: 'Что нового в последней версии: ключевые изменения и исправленные баги.',
    date: '2025-04-28',
    tag: 'Обзор',
    slug: 'obzor-robur-2025-1',
  },
  {
    title: 'Раскладка бетонных плит: от ручного к автоматическому',
    excerpt: 'Эволюция рабочего процесса: от Excel-таблиц до автоматической генерации в Civil 3D.',
    date: '2025-04-01',
    tag: 'Autodesk Civil 3D',
    slug: 'razkladka-plit-avto',
  },
];

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('ru-RU', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<section id="blog" class="bg-base border-b border-line">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 lg:py-28">

    <!-- Section header -->
    <div class="reveal flex items-center gap-5 mb-4">
      <span class="section-label">Блог</span>
      <div class="section-rule"></div>
      <a href="/blog" class="font-mono text-[10px] tracking-widest2 uppercase text-gray-3 hover:text-white transition-colors cursor-pointer shrink-0 flex items-center gap-1.5">
        Все публикации
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="reveal reveal-delay-1 mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold text-white">Новости и статьи</h2>
    </div>

    <!-- Posts -->
    <div class="flex flex-col border border-line divide-y divide-line">
      {posts.map((post, i) => (
        <a
          href={`/blog/${post.slug}`}
          class:list={[
            'group flex gap-6 p-5 hover:bg-surface/60 transition-colors duration-150 cursor-pointer reveal',
            `reveal-delay-${Math.min(i + 1, 4)}`
          ]}
        >
          <!-- Date -->
          <div class="shrink-0 hidden sm:flex flex-col justify-start pt-0.5">
            <span class="font-mono text-[10px] text-gray-3">{formatDate(post.date)}</span>
          </div>

          <!-- Content -->
          <div class="flex-1 min-w-0 flex flex-col gap-1">
            <span class="text-sm font-medium text-white group-hover:text-gray-1 transition-colors leading-snug">{post.title}</span>
            <span class="text-xs text-gray-3 leading-relaxed hidden lg:block">{post.excerpt}</span>
          </div>

          <!-- Tag -->
          <div class="shrink-0 hidden md:flex items-start pt-0.5">
            <span class="font-mono text-[10px] text-gray-4 border border-line px-2 py-0.5">{post.tag}</span>
          </div>

          <!-- Arrow -->
          <div class="shrink-0 flex items-start pt-0.5 text-gray-4 group-hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

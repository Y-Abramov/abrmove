---
const stack = [
  'Topomatic Robur', 'Autodesk Civil 3D', 'Dynamo', 'BIM',
  'C# / .NET', 'Python', 'Продольное проектирование',
  'Поперечные профили', 'ЦММ / ЦМР',
];
---

<section id="about" class="bg-base border-b border-line">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 lg:py-28">

    <!-- Section header -->
    <div class="reveal flex items-center gap-5 mb-4">
      <span class="section-label">О разработчике</span>
      <div class="section-rule"></div>
    </div>

    <div class="reveal reveal-delay-1 mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold text-white">Ярослав Абрамов</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-px bg-line">

      <!-- Left: identity & bio -->
      <div class="bg-base p-8 flex flex-col gap-6">

        <!-- Avatar + title -->
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 border border-line bg-surface flex items-center justify-center font-bold text-white text-sm select-none shrink-0">
            ЯА
          </div>
          <div>
            <div class="font-bold text-white text-sm">Ярослав Абрамов</div>
            <div class="font-mono text-[11px] text-gray-3 mt-0.5">Инженер-проектировщик автомобильных дорог</div>
          </div>
        </div>

        <!-- Robur Expert badge -->
        <div class="inline-flex items-center gap-2 border border-accent-dim bg-accent-glow px-3 py-1.5 w-fit">
          <img src="/logo-mark.svg" alt="" class="w-3.5 h-3.5" />
          <span class="font-mono text-[10px] tracking-widest2 uppercase text-accent">Robur Expert</span>
        </div>

        <!-- Bio -->
        <div class="flex flex-col gap-3">
          <p class="text-sm text-gray-2 leading-relaxed">
            Занимаюсь проектированием автомобильных дорог более 10 лет. Специализируюсь на автоматизации проектных процессов в Topomatic Robur и Autodesk Civil 3D.
          </p>
          <p class="text-sm text-gray-2 leading-relaxed">
            Разрабатываю решения, которые позволяют инженерам быстрее выполнять рутинные операции. Все модули созданы на основе реального опыта: не академические упражнения, а ответ на конкретные проблемы рабочего процесса.
          </p>
        </div>

        <!-- Stack tags -->
        <div class="flex flex-wrap gap-2 pt-2">
          {stack.map((s) => (
            <span class="font-mono text-[10px] text-gray-3 border border-line px-2 py-0.5 hover:border-gray-3 hover:text-gray-1 transition-colors cursor-default">
              {s}
            </span>
          ))}
        </div>
      </div>

      <!-- Right: stats + support -->
      <div class="bg-base flex flex-col divide-y divide-line">

        <!-- Stats -->
        <div class="grid grid-cols-3 divide-x divide-line">
          {[
            { v: '10+', l: 'лет опыта' },
            { v: '50+', l: 'проектов' },
            { v: '5', l: 'модулей' },
          ].map((s) => (
            <div class="p-7 flex flex-col gap-1">
              <span class="font-mono font-bold text-2xl text-white">{s.v}</span>
              <span class="font-mono text-[10px] text-gray-3">{s.l}</span>
            </div>
          ))}
        </div>

        <!-- CTA block -->
        <div class="flex-1 p-8 flex flex-col justify-center gap-6">
          <p class="text-sm text-gray-2 leading-relaxed">
            Все модули бесплатны и открыты для скачивания. Исходники, документация и статьи — по ссылкам ниже.
          </p>

          <div class="flex flex-wrap gap-3">
            <a href="#solutions" class="btn-accent">
              Модули
            </a>
            <a href="https://github.com/Y-Abramov" target="_blank" rel="noopener noreferrer" class="btn-outline">
              Подробнее
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

---
const navItems = [
  { label: 'Главная', href: '#hero' },
  { label: 'Модули', href: '#solutions' },
  { label: 'Новости', href: '#news' },
  { label: 'Документация', href: '#downloads' },
  { label: 'Обо мне', href: '#about' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-line bg-base/80 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group cursor-pointer shrink-0">
        <img src="/logo-mark.svg" alt="ABR MOVE" class="w-7 h-7" />
        <div class="flex flex-col leading-none">
          <span class="font-bold text-sm tracking-widest2 uppercase text-white">ABR</span>
          <span class="font-mono text-[9px] tracking-widest3 uppercase text-gray-3 -mt-0.5">MOVE</span>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-7">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="font-mono text-[11px] tracking-widest2 uppercase text-gray-3 hover:text-white transition-colors duration-150 cursor-pointer"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- CTA -->
      <a href="#downloads" class="hidden md:inline-flex btn-accent shrink-0">
        Скачать
      </a>

      <!-- Mobile toggle -->
      <button id="menu-toggle" class="md:hidden p-1.5 text-gray-3 hover:text-white transition-colors cursor-pointer" aria-label="Меню">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="8" x2="21" y2="8"/>
          <line x1="3" y1="16" x2="21" y2="16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-line bg-surface">
    <nav class="max-w-7xl mx-auto px-6 py-5 flex flex-col gap-4">
      {navItems.map((item) => (
        <a href={item.href} class="font-mono text-xs tracking-widest2 uppercase text-gray-2 hover:text-white transition-colors cursor-pointer">
          {item.label}
        </a>
      ))}
      <a href="#downloads" class="mt-2 btn-accent self-start">
        Скачать модули
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>

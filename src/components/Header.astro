---
interface Props {
  active?: 'home' | 'modules' | 'news';
}
const { active } = Astro.props;

const nav = [
  { label: 'Главная', href: '/', key: 'home' },
  { label: 'Модули', href: '/#mods', key: 'modules' },
  { label: 'Новости', href: '/#news', key: 'news' },
];
---

<header class="site-header">
  <div class="wrap hd">
    <a class="brand" href="/" aria-label="ABR MOVE — на главную">
      <img src="/logo-lockup.svg" alt="ABR | MOVE" />
    </a>

    <nav>
      {nav.map((l) => (
        <a href={l.href} class={active === l.key ? 'on' : ''}>{l.label}</a>
      ))}
    </nav>

    <div class="hd-r">
      <button class="tgl" id="theme-toggle" type="button" aria-label="Переключить тему">
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
        <svg class="icon-moon" viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 14.5A8.5 8.5 0 0 1 9.5 3.5a.5.5 0 0 0-.65-.6A9 9 0 1 0 21.1 15.15a.5.5 0 0 0-.6-.65z"/></svg>
      </button>
    </div>
  </div>
</header>

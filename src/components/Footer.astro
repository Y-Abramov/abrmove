<footer id="footer" class="site-footer">
  <div class="wrap foot-inner">
    <div class="foot-top">
      <a class="foot-brand" href="/" aria-label="ABR MOVE — на главную">
        <img src="/logo-lockup.svg" alt="ABR | MOVE" />
      </a>

      <nav class="foot-nav">
        {nav.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>

      <a class="foot-tg" href="https://t.me/yabramove" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.247l-1.97 9.289c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L7.595 14.7l-2.956-.924c-.643-.204-.657-.643.136-.953l11.532-4.448c.537-.194 1.006.131.255.872z"/></svg>
        Подписаться в Telegram
      </a>
    </div>

    <div class="foot-base">
      <div class="foot-soc">
        {socials.map((s) => (
          <a class={`s-${s.key}`} href={s.href} target="_blank" rel="noopener noreferrer" title={s.label} aria-label={s.label}>
            <svg viewBox="0 0 24 24" fill="currentColor"><path d={s.path} /></svg>
          </a>
        ))}
      </div>

      <div class="foot-meta">
        <a class="foot-mail" href="mailto:Yarlif@yandex.ru">Yarlif@yandex.ru</a>
        <span class="foot-copy">© {new Date().getFullYear()} Ярослав Абрамов</span>
      </div>
    </div>
  </div>
</footer>

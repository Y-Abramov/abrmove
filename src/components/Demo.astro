---
const demos = [
  {
    num: '01',
    title: 'Profile Tracker',
    platform: 'Topomatic Robur',
    desc: 'Пикетаж, отметки, рабочие высоты и уклоны прямо в окне профиля, без переключений.',
    before: 'Переключение между окнами, ручной пересчёт координат, постоянные ошибки при снятии отметок.',
    after: 'Курсор показывает все параметры в реальном времени. Отметка, пикетаж, уклон с первого взгляда.',
  },
  {
    num: '02',
    title: 'RoadStyle',
    platform: 'Topomatic Robur',
    desc: 'Единый интерфейс управления отображением дорог, поверхностей и слоёв проекта.',
    before: 'Десятки кликов через стандартный диалог стилей для каждого элемента отдельно.',
    after: 'Пресет → применить. Стиль всего проекта меняется в несколько кликов.',
  },
  {
    num: '03',
    title: 'Slab Designer',
    platform: 'Autodesk Civil 3D',
    desc: 'Автоматическая раскладка бетонных плит по параметрам поперечного профиля.',
    before: 'Ручная раскладка: часы работы и высокая вероятность ошибок в подсчёте.',
    after: 'Задал параметры → модуль сгенерировал схему за секунды с точным подсчётом.',
  },
];
---

<section id="demo" class="bg-surface/20 border-b border-line">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 lg:py-28">

    <!-- Section header -->
    <div class="reveal flex items-center gap-5 mb-4">
      <span class="section-label">Демонстрация</span>
      <div class="section-rule"></div>
    </div>

    <div class="reveal reveal-delay-1 mb-12">
      <h2 class="text-2xl sm:text-3xl font-bold text-white">До и после</h2>
    </div>

    <div class="flex flex-col gap-px bg-line">
      {demos.map((demo, i) => (
        <div class:list={['reveal bg-base', `reveal-delay-${Math.min(i + 1, 3)}`]}>
          <div class="grid grid-cols-1 lg:grid-cols-12">

            <!-- Info panel -->
            <div class="lg:col-span-4 p-8 border-b lg:border-b-0 lg:border-r border-line flex flex-col gap-4">
              <div class="flex items-center gap-3">
                <span class="font-mono text-[10px] tracking-widest2 text-accent uppercase">{demo.num}</span>
                <span class="font-mono text-[10px] tracking-widest text-gray-3 uppercase">{demo.platform}</span>
              </div>
              <h3 class="font-bold text-white text-lg">{demo.title}</h3>
              <p class="text-sm text-gray-2 leading-relaxed">{demo.desc}</p>

              <!-- Media placeholder -->
              <div class="mt-auto border border-line bg-surface/60 flex items-center justify-center h-24 relative overflow-hidden">
                <div class="absolute inset-0 bg-grid-fine bg-grid-48 opacity-100"></div>
                <div class="relative flex flex-col items-center gap-2 text-gray-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/>
                  </svg>
                  <span class="font-mono text-[10px]">GIF / видео</span>
                </div>
              </div>
            </div>

            <!-- Before / After -->
            <div class="lg:col-span-8 grid grid-cols-1 sm:grid-cols-2">
              <div class="p-8 border-b sm:border-b-0 sm:border-r border-line flex flex-col gap-3">
                <div class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-gray-4"></span>
                  <span class="font-mono text-[10px] tracking-widest2 uppercase text-gray-4">До</span>
                </div>
                <p class="text-sm text-gray-2 leading-relaxed">{demo.before}</p>
              </div>
              <div class="p-8 flex flex-col gap-3">
                <div class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
                  <span class="font-mono text-[10px] tracking-widest2 uppercase text-accent">После</span>
                </div>
                <p class="text-sm text-gray-1 leading-relaxed">{demo.after}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

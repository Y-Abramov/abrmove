---
import { getCollection } from 'astro:content';

interface Props {
  limit?: number;
}
const { limit } = Astro.props;

const allNews = await getCollection('news', ({ data }) => !data.draft);
const sorted = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const news = limit ? sorted.slice(0, limit) : sorted;
const hasMore = !!limit && sorted.length > limit;

const fmt = (d: Date) =>
  d.toLocaleDateString('ru-RU', { day: '2-digit', month: 'short', year: 'numeric' });
---

<section id="news" class="wrap section-pad">
  <div class="sec-head rv">
    <div>
      <div class="sec-k">// ОБНОВЛЕНИЯ</div>
      <h2>Новости</h2>
    </div>
    <p>Релизы модулей, изменения и не только. Обновления прилетают автоматически через Библиотеку.</p>
  </div>

  {news.length === 0 ? (
    <p class="cdesc rv">Здесь скоро появятся новости о модулях и обновлениях.</p>
  ) : (
    <div class="news-list rv">
      {news.map((item) => {
        const Tag = item.data.link ? 'a' : 'div';
        const props = item.data.link
          ? { href: item.data.link, target: '_blank', rel: 'noopener noreferrer' }
          : {};
        return (
          <Tag {...props} class="news-item">
            <span class="nd">{fmt(item.data.date)}</span>
            <span>
              <span class="nt">{item.data.title}</span>
              {item.data.summary && <span class="nb">{item.data.summary}</span>}
            </span>
            {item.data.link && <span class="nlink">Открыть →</span>}
          </Tag>
        );
      })}
    </div>
  )}

  {hasMore && (
    <div class="pt-more rv">
      <a class="btn" href="/news">Все новости <span class="arw">→</span></a>
    </div>
  )}
</section>

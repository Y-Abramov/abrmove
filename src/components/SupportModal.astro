---
const supportPoints = [
  'Больше времени на новые модули',
  'Поддержка и обновления под новые версии Robur',
  'Статьи и видео по реальным задачам проектирования',
];
---

<div id="qr-modal" class="modal">
  <div class="modal-back" id="qr-backdrop"></div>
  <div class="modal-card">
    <button id="qr-close" type="button" aria-label="Закрыть"
      style="position:absolute;top:10px;right:10px;color:var(--faint);background:none;border:0;cursor:pointer;z-index:2">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <div style="display:flex;align-items:center;gap:10px;padding:22px 24px 16px;border-bottom:1px solid var(--line)">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--grade)" stroke="var(--grade)" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      <span style="font-weight:700;font-size:14px">Поддержать автора</span>
    </div>

    <div style="padding:18px 24px;border-bottom:1px solid var(--line)">
      <p style="font-size:12.5px;color:var(--muted);line-height:1.6;margin-bottom:14px">
        Все инструменты я делаю после основной работы — сам сталкивался с теми же задачами. Если хоть один модуль сэкономил час, буду рад поддержке.
      </p>
      <ul style="display:flex;flex-direction:column;gap:8px;list-style:none;padding:0;margin:0">
        {supportPoints.map((p) => (
          <li style="display:flex;align-items:center;gap:8px;font-size:11.5px;color:var(--faint)">
            <span style="width:4px;height:4px;border-radius:50%;background:var(--paint);flex:0 0 auto"></span>{p}
          </li>
        ))}
      </ul>
    </div>

    <div style="padding:22px 24px;display:flex;flex-direction:column;align-items:center;gap:18px">
      <div style="width:170px;height:170px;border:1px solid var(--line);padding:8px;background:var(--panel-2)">
        <img src="/qr-yoomoney.png" alt="QR ЮMoney" style="width:100%;height:100%;object-fit:contain" />
      </div>
      <div style="display:flex;flex-direction:column;align-items:center;gap:3px">
        <span style="font-size:11px;color:var(--faint)">Отсканируйте камерой телефона</span>
        <span class="mono" style="font-size:10px;color:var(--faint)">ЮMoney</span>
      </div>
      <a href="https://yoomoney.ru/to/4100119553658750" target="_blank" rel="noopener noreferrer"
        style="width:100%;display:flex;overflow:hidden;background:#8448FF;transition:background .15s"
        onmouseover="this.style.background='#9560FF'" onmouseout="this.style.background='#8448FF'">
        <span style="display:flex;align-items:center;justify-content:center;padding:0 18px;background:rgba(0,0,0,.25);color:#fff;font-weight:900;font-size:20px">Ю</span>
        <span style="display:flex;align-items:center;justify-content:center;flex:1;padding:13px 16px;color:#fff;font-size:14px;font-weight:600;letter-spacing:.02em">Перевести через ЮMoney</span>
      </a>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('qr-modal');
  const open = () => modal?.classList.add('open');
  const close = () => modal?.classList.remove('open');
  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    if (t.closest('.js-support')) { e.preventDefault(); open(); }
    else if (t.closest('#qr-close') || t.id === 'qr-backdrop') close();
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
</script>

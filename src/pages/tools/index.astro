---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SupportModal from '../../components/SupportModal.astro';
import { tools } from '../../data/tools';
import { downloadHref } from '../../data/counter-endpoint';

const civilTools = tools.filter((t) => t.platform === 'civil');
const dlIcon = 'M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4';
const toolIcon = 'M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z';
---

<Layout
  title="Дополнительные инструменты — ABR | MOVE"
  description="Полезные инструменты и Dynamo-скрипты для Autodesk Civil 3D от практикующего инженера."
>
  <Header active="modules" />

  <main>
    <section class="wrap section-pad">
      <div style="max-width:960px;margin:0 auto">
        <div class="crumb mono"><a href="/">Главная</a> / <b>Дополнительные инструменты</b></div>
        <h1 class="doc-h1">Дополнительные инструменты</h1>
        <p class="doc-lead">Отдельные утилиты и Dynamo-скрипты под конкретные задачи. Это не модули ABR — самостоятельные инструменты. Нажмите, чтобы открыть инструкцию.</p>

        <div class="ptabs seg-nav" role="tablist" aria-label="Раздел каталога">
          <a class="ptab" href="/modules">Все модули</a>
          <a class="ptab on" href="/tools" aria-current="page">Дополнительные инструменты</a>
        </div>

        <div class="mgrp">
          <span class="mgrp-t mono">Autodesk Civil 3D</span>
          <span class="mgrp-c mono">{civilTools.length}</span>
        </div>
        <div class="mlist2">
          {civilTools.map((t) => (
            <div class="mrow">
              <a class="mrow-main" href={`/tools/${t.slug}`}>
                <span class="mrow-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d={toolIcon}/></svg></span>
                <span class="mrow-b">
                  <span class="mrow-t">{t.name}</span>
                  <span class="mrow-d">{t.short}</span>
                </span>
              </a>
              <div class="mrow-meta">
                <span class="mrow-tags">{t.tags.map((tag) => <span class="badge">{tag}</span>)}</span>
                {t.download && (
                  <a class="mrow-dl" href={downloadHref('tool', t.slug, t.download)} target="_blank" rel="noopener noreferrer"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d={dlIcon}/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Скачать</a>
                )}
                <a class="mrow-more mono" href={`/tools/${t.slug}`}>Открыть →</a>
              </div>
            </div>
          ))}
        </div>

        <div class="mgrp soon">
          <span class="mgrp-t mono">Топоматик Robur</span>
          <span class="mgrp-c mono">В ПЛАНАХ</span>
        </div>
        <div class="mempty">Инструменты для Robur — в планах.</div>
      </div>
    </section>
  </main>

  <Footer />
  <SupportModal />
</Layout>

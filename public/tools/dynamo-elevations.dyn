    {
      "ConcreteType": "CoreNodeModels.Input.DoubleInput, CoreNodeModels",
      "NodeType": "NumberInputNode",
      "NumberType": "Double",
      "InputValue": 5.0,
      "Id": "d4e541a9ddf449a6b3248c6d39a49a3a",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "c778d75cf5764c529eee18f6255a3e25",
          "Name": "",
          "Description": "Double",
          "UsingDefaultValue": false,

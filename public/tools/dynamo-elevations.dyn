    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import sys\r\nimport clr\r\n\r\nclr.AddReference('AcMgd')\r\nclr.AddReference('AcDbMgd')\r\nclr.AddReference('AeccDbMgd')\r\nclr.AddReference('Civil3DNodes')\r\n\r\nimport Autodesk.AutoCAD.ApplicationServices as acApp\r\nimport Autodesk.AutoCAD.DatabaseServices as acDb\r\n\r\nraw_profiles = IN[0]\r\ndelta        = float(IN[1])\r\nenabled      = IN[2]\r\n\r\nif not enabled:\r\n    OUT = [\"Профили: пропущено\"]\r\nelse:\r\n    if not isinstance(raw_profiles, list):\r\n        raw_profiles = [raw_profiles]\r\n\r\n    civil_objects = []\r\n    for item in raw_profiles:\r\n        if isinstance(item, list):\r\n            civil_objects.extend(item)\r\n        else:\r\n            civil_objects.append(item)\r\n\r\n    acDoc  = acApp.Application.DocumentManager.MdiActiveDocument\r\n    report = []\r\n\r\n    try:\r\n        with acDoc.LockDocument():\r\n            with acDoc.Database.TransactionManager.StartTransaction() as tr:\r\n                try:\r\n                    for obj in civil_objects:\r\n                        if obj is None:\r\n                            continue\r\n                        try:\r\n                            oid         = obj.InternalObjectId\r\n                            native_prof = tr.GetObject(\r\n                                oid, acDb.OpenMode.ForWrite)\r\n                            pvi_col     = native_prof.PVIs\r\n                            pvi_count   = pvi_col.Count\r\n                            for idx in range(pvi_count):\r\n                                pvi = pvi_col[idx]\r\n                                pvi.Elevation = pvi.Elevation + delta\r\n                            report.append(\"OK | Profile: {} | PVI: {}\".format(\r\n                                native_prof.Name, pvi_count))\r\n                        except Exception as p_ex:\r\n                            report.append(\"ERR | \" + str(p_ex))\r\n                    tr.Commit()\r\n                except Exception as tx_ex:\r\n                    report.append(\"TRANSACTION ERROR: \" + str(tx_ex))\r\n                    tr.Abort()\r\n    except Exception as lock_ex:\r\n        report = [\"LOCK ERROR: \" + str(lock_ex)]\r\n\r\n    OUT = report",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "3d34429372ee449e85f1ff6c941c9549",

  "Outputs": [],
  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import sys\r\nimport clr\r\n\r\nclr.AddReference('AcMgd')\r\nclr.AddReference('AcDbMgd')\r\nclr.AddReference('AeccDbMgd')\r\nclr.AddReference('Civil3DNodes')\r\n\r\nimport Autodesk.AutoCAD.ApplicationServices as acApp\r\nfrom Autodesk.Civil.DynamoNodes.LandDevelopment import FeatureLine as C3DFeatureLine\r\n\r\n# ── входные данные ──────────────────────────────────────────\r\nraw_fls = IN[0]\r\ndelta   = float(IN[1])\r\n\r\nif not isinstance(raw_fls, list):\r\n    raw_fls = [raw_fls]\r\ncivil_objects = []\r\nfor item in raw_fls:\r\n    if isinstance(item, list):\r\n        civil_objects.extend(item)\r\n    else:\r\n        civil_objects.append(item)\r\n\r\nacDoc  = acApp.Application.DocumentManager.MdiActiveDocument\r\nreport = []\r\n\r\ntry:\r\n    with acDoc.LockDocument():\r\n        for obj in civil_objects:\r\n            if obj is None:\r\n                continue\r\n            try:\r\n                # Приводим CivilObject → FeatureLine\r\n                fl    = C3DFeatureLine.ByObject(obj)\r\n                pts   = fl.GetAllPoints()\r\n                count = len(pts)\r\n\r\n                report.append(\"DEBUG: fl={} pts={}\".format(fl, count))\r\n\r\n                for i in range(count):\r\n                    fl.SetPointRelativeElevationByIndex(i, delta)\r\n\r\n                report.append(\"OK | FL: {} | точек: {}\".format(fl.Name, count))\r\n            except Exception as fl_ex:\r\n                report.append(\"ERR | \" + str(fl_ex))\r\n\r\nexcept Exception as lock_ex:\r\n    report = [\"LOCK ERROR: \" + str(lock_ex)]\r\n\r\nOUT = report",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "9a7a864377534ea88450cedb1293a13c",
      "Inputs": [
